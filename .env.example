# ============================================================================
# Agent B - Environment Variables Template
# ============================================================================
#
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# ============================================================================

# ============================================================================
# Application Configuration (B0.0.3) - IMPLEMENTED
# ============================================================================

# Application name
APP_NAME=Agent B

# Environment: development, production, test
ENVIRONMENT=development

# Enable debug mode (more verbose logging, dev tools)
DEBUG=false

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# Logging Configuration (B0.0.3) - IMPLEMENTED
# ============================================================================

# Global log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output format: json (structured) or text (human-readable)
LOG_FORMAT=json

# Optional: Log to file (if not set, logs only to stdout)
# LOG_FILE=logs/agent-b.log

# Log file rotation settings (only used if LOG_FILE is set)
# LOG_FILE_MAX_BYTES=10485760  # 10MB
# LOG_FILE_BACKUP_COUNT=5

# Component-specific log levels (override LOG_LEVEL for specific components)
# LOG_LEVEL_DATABASE=INFO
# LOG_LEVEL_DOCKER=INFO
# LOG_LEVEL_API=INFO

# ============================================================================
# Database Configuration (B0.0.2) - IMPLEMENTED
# ============================================================================

# PostgreSQL connection string (async driver)
# Format: postgresql+asyncpg://user:password@host:port/database
# DATABASE_URL=postgresql+asyncpg://agentb:password@localhost:5432/agentb

# Database pool configuration
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Enable SQL query logging (for development/debugging)
# DB_ECHO=false

# ============================================================================
# Docker Execution Configuration (B0.1+)
# ============================================================================

# Docker execution settings
# DOCKER_TIMEOUT=300
# DOCKER_MEMORY_LIMIT=2g
# DOCKER_CPU_LIMIT=1.0

# Workspace directory (where sandboxed code executes)
# WORKSPACE_DIR=./workspace

# ============================================================================
# LLM Provider Configuration (B2.0+)
# ============================================================================

# --- Gemini (Google AI) ---
# Get your API key from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenRouter ---
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- OpenAI ---
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# --- Anthropic (Claude) ---
# Get your API key from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Ollama (Local Models) ---
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Multi-Brain Configuration (B2.2+)
# ============================================================================

# Brain 1 (Primary Reasoning)
# BRAIN_1_PROVIDER=gemini
# BRAIN_1_MODEL=gemini-1.5-flash
# BRAIN_1_TEMPERATURE=0.7

# Brain 2 (Critique and Repair)
# BRAIN_2_PROVIDER=gemini
# BRAIN_2_MODEL=gemini-1.5-pro
# BRAIN_2_TEMPERATURE=0.5

# Brain 3 (External Advisory)
# BRAIN_3_PROVIDER=openrouter
# BRAIN_3_MODEL=anthropic/claude-3.5-sonnet
# BRAIN_3_TEMPERATURE=0.3

# ============================================================================
# Agent B Behavior Configuration
# ============================================================================

# Risk tolerance: conservative, moderate, aggressive
# RISK_TOLERANCE=moderate

# Escalation threshold (0.0-1.0, lower = escalate more often)
# ESCALATION_THRESHOLD=0.7

# Maximum retry attempts before escalation
# MAX_RETRY_ATTEMPTS=5

# Default operational mode
# MODE=engineering

# ============================================================================
# Security Configuration (B0.0.4) - IMPLEMENTED
# ============================================================================

# Authentication
# Enable/disable authentication (default: false for local dev)
AUTH_ENABLED=false

# Session token configuration (required if AUTH_ENABLED=true)
# Generate with: openssl rand -hex 32
# SESSION_SECRET_KEY=your_64_character_secret_key_here

# Session expiration (hours, default: 24)
SESSION_EXPIRE_HOURS=24

# Encryption key for API keys at rest (required for API key storage)
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=your_64_character_encryption_key_here

# CORS configuration (Architecture A: separate frontend)
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Resource Limits (B0.0.1) - IMPLEMENTED
# ============================================================================

# Minimum required resources (for health checks)
MIN_DISK_SPACE_GB=5
MIN_MEMORY_GB=4

# ============================================================================
# Monitoring and Metrics (B7.2+)
# ============================================================================

# Enable Prometheus metrics endpoint
# ENABLE_METRICS=true
# METRICS_PORT=9090

# ============================================================================
# Backup Configuration (B7.1+)
# ============================================================================

# Automated backup schedule (cron format)
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=30

# ============================================================================
# Development and Debugging
# ============================================================================

# Enable request/response logging (automatic when LOG_LEVEL=DEBUG)
# LOG_REQUESTS=true

# Enable LLM request/response logging (can be expensive)
# LOG_LLM_REQUESTS=false

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable specific features during development
# ENABLE_EXTERNAL_TOOLS=false
# ENABLE_GITHUB_INTEGRATION=false
# ENABLE_EMAIL_NOTIFICATIONS=false

# ============================================================================
# Notes
# ============================================================================
#
# Security Best Practices:
# - Never commit .env to version control
# - Use strong, randomly generated secrets
# - Rotate API keys regularly
# - Use environment-specific .env files (.env.production, .env.staging)
# - Consider using a secrets manager for production
#
# Generate a secure secret key:
#   openssl rand -hex 32
#
# ============================================================================



# --- XiaoLei API (chat bridge) ---
# Default model used by /xiaolei_api/chat endpoint (Veritas Core LLM client)
# XIAOLEI_LLM_PROVIDER=openrouter
# XIAOLEI_LLM_MODEL=openai/gpt-5.2
# XIAOLEI_LLM_TEMPERATURE=0.7
# XIAOLEI_LLM_MAX_TOKENS=1024
# XIAOLEI_LLM_TIMEOUT_S=30

