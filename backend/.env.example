# Agent B Configuration Example
# Copy this file to .env and configure with your values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Agent B
ENVIRONMENT=development  # development, production, test
DEBUG=false

# ============================================================================
# API Settings
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# Database Settings
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://agentb:agentb_password@localhost:5432/agentb

# ============================================================================
# Docker Settings (B0.0.1)
# ============================================================================
# Minimum system requirements
MIN_DISK_SPACE_GB=5.0
MIN_MEMORY_GB=4.0

# ============================================================================
# Docker Execution Settings (B0.1)
# ============================================================================
# Command execution timeout in seconds (default: 300 = 5 minutes)
DOCKER_TIMEOUT=300

# Enable network access in Docker containers (default: false for security)
DOCKER_NETWORK_ENABLED=false

# Allowed networks for Docker containers (comma-separated)
# Only used if DOCKER_NETWORK_ENABLED=true
DOCKER_NETWORK_ALLOWLIST=

# Directory for workspace file mounting
WORKSPACE_DIR=./workspace

# Memory limit for Docker containers (e.g., '2g', '512m', '4g')
DOCKER_MEMORY_LIMIT=2g

# CPU limit for Docker containers (number of cores, e.g., 1.0, 2.0, 0.5)
DOCKER_CPU_LIMIT=1.0

# ============================================================================
# Execution Safety Settings (B0.2)
# ============================================================================
# Dangerous command patterns that are always blocked (comma-separated)
COMMAND_BLOCKLIST=rm -rf /,dd if=,:(){ :|:& };:,mkfs

# High-risk command patterns that require approval (comma-separated)
HIGH_RISK_PATTERNS=rm,dd,mkfs,format

# ============================================================================
# Logging Settings (B0.0.3)
# ============================================================================
# Global log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output format: json, text
LOG_FORMAT=json

# Log file path (leave empty for stdout only)
LOG_FILE=

# Maximum log file size in bytes before rotation (default: 10MB)
LOG_FILE_MAX_BYTES=10485760

# Number of rotated log files to keep
LOG_FILE_BACKUP_COUNT=5

# Component-specific log levels (optional, overrides LOG_LEVEL)
LOG_LEVEL_DATABASE=
LOG_LEVEL_DOCKER=
LOG_LEVEL_API=

# ============================================================================
# Authentication Settings (B0.0.4)
# ============================================================================
# Enable authentication for protected endpoints
AUTH_ENABLED=false

# Secret key for JWT session tokens (required if AUTH_ENABLED=true)
# Generate with: openssl rand -hex 32
SESSION_SECRET_KEY=

# Session token expiration time in hours (default: 24)
SESSION_EXPIRE_HOURS=24

# Encryption key for API keys at rest (required if using API key storage)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================================
# CORS Settings
# ============================================================================
# Enable CORS middleware
CORS_ENABLED=true

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Testing
# ============================================================================
# Skip Docker integration tests (set to 1 to skip)
SKIP_DOCKER_TESTS=0
